{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/compliance-check",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/compliance-check",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/fastag-simulate",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/cron/insurance-check",
      "schedule": "15 0 * * *"
    }
  ]
}
