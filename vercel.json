{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/compliance-check",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/fastag-simulate",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/insurance-check",
      "schedule": "15 0 * * *"
    },
    {
      "path": "/api/cron/subscription-expiry",
      "schedule": "45 0 * * *"
    },
    {
      "path": "/api/cron/subscription-reminder",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/billing",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/credit-card-alerts",
      "schedule": "30 3 * * *"
    }
  ]
}
